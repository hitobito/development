#!/usr/bin/env bash

copy_gemfile_lock() {
  (
    cd $HIT_CORE_DIR
    git checkout Gemfile.lock
    cp Gemfile.lock ${BUNDLE_GEMFILE}.lock
  ) > /dev/null 2>&1
  echo "Changes to Gemfile.lock are ignored, check hitobito/doc/developer/local_setup.md for more details."
  echo
}

if [ -n $BUNDLE_GEMFILE ]; then
  copy_gemfile_lock
fi
